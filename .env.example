# ===========================
# Chase Bank Voice Agent Platform
# Production Environment Configuration
# ===========================

# Frontend Configuration
NEXT_PUBLIC_API_URL=https://api.bankchase.example.com
NEXTAUTH_URL=https://bankchase.example.com
NEXTAUTH_SECRET=<generate-with: openssl rand -hex 32>

# Database
DATABASE_URL=postgresql://user:password@host:5432/bankchase_prod
DATABASE_POOL_SIZE=20
DATABASE_IDLE_TIMEOUT=10m

# Authentication
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# API Keys
ADMIN_API_KEY=<generate-secure-key>
VOICE_API_KEY=<generate-secure-key>

# Voice Agent Configuration
VOICE_BIOMETRICS_MODEL=pgvector_cosine
LIVENESS_DETECTION_MODEL=wavlm
BEHAVIORAL_DRIFT_THRESHOLD=0.75

# Monitoring & Error Tracking
SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
SENTRY_ENV=production
SENTRY_SAMPLE_RATE=0.1

# Email Configuration
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=<sendgrid-api-key>
SMTP_FROM=noreply@bankchase.example.com

# Feature Flags
ENABLE_VOICE_BIOMETRICS=true
ENABLE_BEHAVIORAL_DRIFT_DETECTION=true
ENABLE_DEMO_MONEY_SYSTEM=true
ENABLE_SSO=false
ENABLE_SCIM=false

# Rate Limiting
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_API=100/minute
RATE_LIMIT_DEMO_TRANSFER=10/minute

# Caching
REDIS_URL=redis://host:6379
CACHE_TTL_ACCOUNTS=300
CACHE_TTL_TRANSACTIONS=60

# Background Jobs
APScheduler_TIMEZONE=UTC
DEMO_REFUND_CHECK_TIME=02:00
DEMO_REFUND_RETENTION_DAYS=7,14

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Security
CORS_ORIGINS=https://bankchase.example.com
ALLOWED_DOMAINS=bankchase.example.com
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_DURATION=15m

# Demo Account Settings
DEMO_ACCOUNT_INITIAL_BALANCE=10000
DEMO_ACCOUNT_MAX_DAILY_TRANSFER=5000
DEMO_FUNDS_AUTO_REFUND=true

# Audit & Compliance
ENABLE_AUDIT_LOGGING=true
AUDIT_LOG_RETENTION_DAYS=365
ENABLE_COMPLIANCE_CHECKS=true

# Development (do NOT use in production)
# DEBUG=false
# ALLOWED_HOSTS=localhost,127.0.0.1
