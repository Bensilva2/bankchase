# ============================================
# BANKCHASE - NEXT.JS + SUPABASE CONFIG
# ============================================
# Copy this to .env.local and configure for your environment

# ============================================
# SUPABASE CONFIGURATION
# ============================================

# Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Site URL for production (set in Vercel environment)
# This should match one of your Supabase redirect URLs
NEXT_PUBLIC_SITE_URL=https://demo-nextjs-with-supabase.vercel.app

# ============================================
# MONGODB CONFIGURATION (Hybrid Architecture)
# ============================================

# MongoDB Atlas connection string
# Format: mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@your-cluster.mongodb.net/bankchase?retryWrites=true&w=majority

# For local MongoDB:
# MONGODB_URI=mongodb://localhost:27017/bankchase

# MongoDB collections:
# - notifications: User notifications with TTL
# - preferences: User preferences and settings
# - transactions: Detailed transaction records
# - analytics: Monthly transaction analytics
# - devices: Registered devices for user accounts
# - auditLogs: Audit trail with 90-day TTL

# ============================================
# DATABASE CONFIGURATION (PostgreSQL via Supabase)
# ============================================

# PostgreSQL connection string (from Supabase)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bankchase
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/bankchase

# Database credentials (for Docker Compose)
DB_NAME=bankchase
DB_USER=postgres
DB_PASSWORD=postgres

# ============================================
# JWT & AUTHENTICATION
# ============================================

# JWT signing secret (generate: openssl rand -base64 32)
JWT_SECRET=your-secret-key-min-32-characters-long-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRATION=86400

# Supabase uses its own JWT internally, but you can add custom claims
NEXT_PUBLIC_SUPABASE_JWT_EXPIRATION=3600

# ============================================
# ADMIN SETUP
# ============================================

# Initial admin user
ADMIN_EMAIL=admin@bankchase.com
ADMIN_PASSWORD=ChangeMeInProduction123!

# ============================================
# ENVIRONMENT & LOGGING
# ============================================

ENVIRONMENT=development
LOG_LEVEL=DEBUG

# ============================================
# FEATURE FLAGS
# ============================================

ENABLE_BIOMETRIC=true
ENABLE_BEHAVIORAL_DRIFT=true
ENABLE_LIVENESS_DETECTION=true
ENABLE_WEBHOOKS=true

# ============================================
# REDIS (for rate limiting & caching)
# ============================================

REDIS_URL=redis://localhost:6379/0

# ============================================
# WEBHOOK CONFIGURATION
# ============================================

WEBHOOK_RETRY_MAX=3
WEBHOOK_RETRY_DELAY=5
WEBHOOK_TIMEOUT=30
WEBHOOK_BASE_URL=http://localhost:8000

# ============================================
# RATE LIMITING
# ============================================

TRANSFER_RATE_LIMIT=10
ADMIN_RATE_LIMIT=20

# ============================================
# SECURITY
# ============================================

CORS_ORIGINS=http://localhost:3000,http://localhost:8000
ENFORCE_HTTPS=false
SESSION_TIMEOUT=3600

# ============================================
# BEHAVIORAL DRIFT DETECTION
# ============================================

BASELINE_TRANSACTIONS=10
DRIFT_THRESHOLD=0.7
DRIFT_REQUIRE_VERIFICATION=true

# ============================================
# PIN SECURITY
# ============================================

PIN_MAX_ATTEMPTS=3
PIN_LOCKOUT_DURATION=15

# ============================================
# DEMO MODE
# ============================================

DEMO_MODE=true
DEMO_INITIAL_BALANCE=50000.00

# ============================================
# EMAIL (optional)
# ============================================

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@bankchase.com

# ============================================
# MONITORING (optional)
# ============================================

DATADOG_API_KEY=
SENTRY_DSN=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ============================================
# DEVELOPMENT
# ============================================

DEBUG=false
RELOAD=true
DISABLE_CSRF=false
